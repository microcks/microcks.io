{{- .Scratch.Set "type" "article" -}}
{{- if eq .Type "blog" -}}
  {{- .Scratch.Set "type" "blogPosting" -}}
{{- else if eq .Section "documentation" -}}
  {{- .Scratch.Set "type" "techArticle" -}}
{{- end -}}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "{{ .Scratch.Get "type" }}",
  "headline": "{{ .Title | jsonify }}",
  {{- if .Description }}
  "description": "{{ .Description | jsonify }}",
  {{- end }}
  {{- if .Params.author }}
  "author": {
    "@type": "Person",
    "name": "{{ .Params.author }}"
  },
  {{- end }}
  {{- if .PublishDate }}
  "datePublished": "{{ .PublishDate.Format "2006-01-02T15:04:05Z07:00" }}",
  {{- end }}
  {{- if .Lastmod }}
  "dateModified": "{{ .Lastmod.Format "2006-01-02T15:04:05Z07:00" }}",
  {{- end }}
  {{- with .Params.image }}
  "image": "{{ $.Site.BaseURL }}{{ . }}",
  {{- end }}
  "url": "{{ .Permalink }}",
  {{- if .IsPage }}
  {{- else }}
  "publisher": {
    "@type": "Organization",
    "name": "Microcks",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ .Site.BaseURL }}images/logo.png"
    }
  },
  {{- end }}
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ .Permalink }}"
  }
}
</script>
